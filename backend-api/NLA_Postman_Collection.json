    {
      "name": "Connections (Inquiries)",
      "item": [
        {
          "name": "Send Connection Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/connections",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"athlete-uuid\",\n  \"name\": \"John Recruiter\",\n  \"email\": \"john@agency.com\",\n  \"reason\": \"recruitment\",\n  \"message\": \"We would love to have you on our team...\",\n  \"captchaToken\": \"TEST_RECAPTCHA_TOKEN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Received Connections",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/connections/received",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Update Connection Status",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/connections/:id/status",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"READ\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Reply to Connection (sends email)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/connections/:id/reply",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"replyMessage\": \"Thank you for reaching out! I would love to discuss this opportunity further.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
