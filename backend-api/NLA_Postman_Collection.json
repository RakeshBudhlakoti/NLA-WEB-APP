{
  "info": {
    "name": "NLA Sports Platform API v2",
    "description": "Complete API collection for the NLA Sports Platform. Set the `base_url` and `access_token` variables before use.\n\n⚠️ Auth endpoints (Register, Send OTP) require a valid Google reCAPTCHA v2 token in the `captchaToken` field. Use test token for development.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP (Forgot Password)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/send-otp",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"athlete@nlasports.com\",\n  \"captchaToken\": \"TEST_RECAPTCHA_TOKEN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/verify-otp",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"athlete@nlasports.com\",\n  \"otp\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"athlete@nlasports.com\",\n  \"password\": \"Password1\",\n  \"fullName\": \"Marcus Stone\",\n  \"captchaToken\": \"TEST_RECAPTCHA_TOKEN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"athlete@nlasports.com\",\n  \"password\": \"Password1\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Athletes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/athletes?page=1&limit=12"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/:id"
          }
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/stats",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/users/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Marcus Stone\",\n  \"tagline\": \"Champion Wrestler\",\n  \"bio\": \"My journey...\",\n  \"city\": \"New York\",\n  \"avatarUrl\": \"avatars/filename.jpg\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Posts (Stories)",
      "item": [
        {
          "name": "Get Posts (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts?page=1&limit=10&category=uuid&isExclusive=false"
          }
        },
        {
          "name": "Get My Posts",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts/my-posts",
            "header": [
